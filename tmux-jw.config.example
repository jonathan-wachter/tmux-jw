# tmux-jw.config.example — optional local configuration for the tmux-jw hooks.
#
# Setup:   cp tmux-jw.config.example tmux-jw.config   # then edit
# The real tmux-jw.config is git-ignored, so your local values never get
# committed. Every setting is OPTIONAL — with no config file at all, the
# defaults shown below apply. This file is sourced by bash (plain VAR=value
# lines; quote values containing spaces).

# Name of the "parking" session — where the cockpit's park action stashes
# windows you want out of the way. Created on first use if missing.
#TMUXJW_PARKING=cc-parking

# Prefix for new blank sessions created from the cockpit's (s) key.
# The session is named <prefix><mmdd>, e.g. cc-0709 for July 9.
#TMUXJW_SESSION_PREFIX=cc-

# tmux binary the test suite drives (tests/run-tests.sh). Defaults to the
# first tmux on PATH. Point it elsewhere if you test against a patched build.
#TMUXJW_TMUX_BIN=/opt/homebrew/bin/tmux

# Red "P?" badge on Claude windows with no project association (set via the
# session-pipelines `assoc` workflow). auto = show only when the assoc state
# dir (~/projects/session-pipelines/state/assoc) exists; force with 1 or 0.
#TMUXJW_PROJ_MARKER=auto
